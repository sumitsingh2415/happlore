# ─── Application ────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Database ────────────────────────────────────────────────────────
# Replace with your actual PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/happlore?schema=public"

# ─── JWT ─────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRES_IN=30d

# ─── Redis (BullMQ Queue) ────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── SendGrid (Email) ────────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=hello@happlore.com
EMAIL_FROM_NAME=Happlore

# ─── Twilio (WhatsApp + SMS) ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=+1234567890

# ─── Admin ───────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@happlore.com

# ─── CORS ────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://happlore.com
